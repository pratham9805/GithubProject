# ============================================================
# GitHub QA Bot — Environment Variables
# Copy this file to .env and fill in your actual keys.
# ============================================================

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Pinecone API Key (https://app.pinecone.io/)
PINECONE_API_KEY=pcsk_...

# Pinecone index name (must already exist in your Pinecone project)
PINECONE_INDEX_NAME=

# GitHub Personal Access Token (https://github.com/settings/tokens)
# Scopes needed: public_repo (or repo for private repos)
GITHUB_TOKEN=ghp_...

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# Optional: override default AI models
# DEFAULT_CHAT_MODEL=gpt-4.1-mini
# DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
